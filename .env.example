# Supabase — used by the app (Vite client) and the keep-alive function (api/keep-alive.js)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: shared secret for the scheduled keep-alive endpoint.
# Set the same value in the Vercel project; Vercel Cron sends it as a Bearer token.
CRON_SECRET=
